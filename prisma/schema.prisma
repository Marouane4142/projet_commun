// ---------------------------------------------------------------------------
// Prisma n'est PAS utilise en production dans ce projet.
// Le schema est conserve a titre documentaire pour refleter le modele de
// donnees reel de Supabase (PostgreSQL). Les tables sont creees via les
// fichiers SQL dans le dossier sql/.
// ---------------------------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Profil applicatif d'un utilisateur (lie a auth.users via Supabase Auth).
model g1a_profiles {
  id            String   @id @db.Uuid
  pseudo        String
  role          String   @default("client")
  favorite_team String?
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @default(now()) @db.Timestamptz()
}

/// Evenements FanBar (soirees de match avec cartes electroniques assignees).
model g1a_events {
  id               Int       @id @default(autoincrement())
  name             String
  match_id         String
  competition      String?
  home_team        String
  away_team        String
  kickoff_at       DateTime? @db.Timestamptz()
  zone_a_team      String
  zone_b_team      String
  zone_a_card      String
  zone_b_card      String
  status           String    @default("planned")
  final_home_score Int?
  final_away_score Int?
  finished_at      DateTime? @db.Timestamptz()
  created_at       DateTime  @default(now()) @db.Timestamptz()
  updated_at       DateTime  @default(now()) @db.Timestamptz()
}

/// Pronostics des supporters sur les matchs.
model g1a_predictions {
  id             Int      @id @default(autoincrement())
  user_id        String   @db.Uuid
  event_id       Int
  pseudo         String
  predicted_home Int
  predicted_away Int
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @db.Timestamptz()

  @@unique([user_id, event_id])
}

/// Diffusions video (resumes / lives Coupe du Monde 2026).
model g1a_broadcasts {
  id           Int       @id @default(autoincrement())
  title        String
  youtube_id   String    @unique
  match_label  String?
  kind         String    @default("resume")
  published_at DateTime? @db.Timestamptz()
  created_by   String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz()
}

/// Alias des sujets d'alcoolemie (renommage par un gerant).
model g1a_subject_aliases {
  subject_id String   @id
  alias      String
  updated_at DateTime @default(now()) @db.Timestamptz()
}

/// Liaison sujet d'alcoolemie <-> compte utilisateur.
model g1a_subject_links {
  subject_id String   @id
  user_id    String   @db.Uuid
  linked_by  String?  @db.Uuid
  linked_at  DateTime @default(now()) @db.Timestamptz()
}

/// Mesures sonores du capteur G1A (notre groupe).
model g1a_sound {
  id              Int      @id @default(autoincrement())
  db_value        Float
  measured_at     DateTime @db.Timestamptz()
  electronic_card Int?
  created_at      DateTime @default(now()) @db.Timestamptz()
}
