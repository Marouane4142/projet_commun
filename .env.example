# =============================================================================
# FanBar Arena - Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# =============================================================================

# ---- Supabase (obligatoire) ----
NEXT_PUBLIC_SUPABASE_URL="https://XXXXXXXX.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# ---- API Football (obligatoire pour matchs / equipes) ----
FOOTBALL_API_BASE_URL="https://soccer.highlightly.net"
FOOTBALL_API_KEY="your_api_key_here"
FOOTBALL_SEASON="2026"

# ---- Passerelle cartes electroniques (optionnel) ----
# FANBAR_BRIDGE_URL="http://127.0.0.1:8765"

# ---- Token d'ecriture capteur son (optionnel) ----
# SENSOR_WRITE_TOKEN="your_secret_token_here"
